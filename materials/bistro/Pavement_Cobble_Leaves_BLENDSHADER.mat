pipelines:
flags:
    - two_sided
textures:
    - bistro/Pavement_Cobble_Leaves_BLENDSHADER_BaseColor.tex
    - bistro/Pavement_Cobble_Leaves_BLENDSHADER_Normal.tex
    - default_opacity.tex
params:
    - 1.0 1.0 1.0 0.3    # base color, roughness
    - 0.0 0.0 0.9 0.0    # sheen, sheen_tint, specular, spec_tint
    - 2.0 0.0 0.0 0.0    # metallic, transmission, clearcoat, clearcoat_roughness
    - 0.0 0.0 0.0 0.0    # transparency, ior/emission color
