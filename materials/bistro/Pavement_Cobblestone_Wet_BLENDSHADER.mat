pipelines:
flags:
    - two_sided
textures:
    - bistro/Pavement_Cobblestone_Wet_BLENDSHADER_BaseColor.tex
    - bistro/Pavement_Cobblestone_Wet_BLENDSHADER_Normal.tex
    - bistro/_Pavement_Cobblestone_Wet_BLENDSHADER_roughness.tex
    - bistro/_Pavement_Cobblestone_Wet_BLENDSHADER_metallic.tex
    - default_opacity.tex
params:
    - 1.0 1.0 1.0 0.5    # base color, roughness
    - 0.0 0.0 1.9 0.0    # sheen, sheen_tint, specular, spec_tint
    - 0.3 2.5 0.0 0.0    # metallic, transmission, clearcoat, clearcoat_roughness
    - 0.0 1.53 0.0 0.0    # transparency, ior/emission color
