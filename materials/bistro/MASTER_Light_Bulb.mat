pipelines:
flags:
    - emissive
textures:
    - bistro/MASTER_Light_Bulb_BaseColor.tex
    - bistro/MASTER_Light_Bulb_Normal.tex
    - bistro/MASTER_Light_Bulb_roughness.tex
    - bistro/MASTER_Light_Bulb_metallic.tex
    - default_opacity.tex
    - bistro/Paris_Ceiling_Lamp_Emissive.tex
params:
    - 1.0 1.0 1.0 1.0    # base color, roughness
    - 0.0 0.0 0.5 0.0    # sheen, sheen_tint, specular, spec_tint
    - 1.0 0.0 0.0 0.0    # metallic, transmission, clearcoat, clearcoat_roughness
    - 0.0 10.0 10.0 10.0    # transparency, ior/emission color
